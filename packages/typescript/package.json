{
  "name": "langchain-task-steering",
  "version": "0.1.5",
  "description": "Implicit state machine middleware for LangChain.js agents. Ordered task pipelines with per-task tool scoping, prompt injection, and composable validation.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 100,
    "trailingComma": "es5"
  },
  "keywords": [
    "langchain",
    "langgraph",
    "agents",
    "middleware",
    "state-machine",
    "task-pipeline"
  ],
  "author": "Edvin Hallvaxhiu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/edvinhallvaxhiu/langchain-task-steering",
    "directory": "packages/typescript"
  },
  "devDependencies": {
    "@langchain/aws": "^1.3.4",
    "@langchain/core": "^1.1.39",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "zod": "^4.3.6"
  }
}
